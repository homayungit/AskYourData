{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/askyourdata-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "OllamaSettings": {
    "BaseUrl": "http://localhost:11434",
    "ChatModel": "qwen2.5:32b-instruct-q4_K_M",
    "EmbeddingModel": "bge-m3",
    "NumCtx": 16384,
    "Temperature": 0.1,
    "TopP": 0.9,
    "RepeatPenalty": 1.05,
    "KeepAlive": "30m",
    "RequestTimeoutSeconds": 120
  },
  "OpenAIFallback": {
    "Enabled": false,
    "ApiKey": "YOUR_OPENAI_API_KEY",
    "ChatModel": "gpt-4o-mini",
    "EmbeddingModel": "text-embedding-3-small"
  },
  "QdrantSettings": {
    "Host": "localhost",
    "Port": 6334,
    "CollectionName": "my_database_chunks"
  },
  "ChatbotSettings": {
    "MaxContextRows": 200,
    "TopKVectorResults": 5,
    "SqlTimeoutSeconds": 30,
    "EnableDebugInfo": false,
    "IngestApiKey": "CHANGE_ME_USE_A_STRONG_RANDOM_SECRET",
    "SystemPrompt": "You are AskYourData, an AI assistant for querying business databases.\n\nCRITICAL RULES:\n1. The LIVE DATA section contains real SQL query results that directly answer the question. ALWAYS use this data to form your answer.\n2. When the live data contains a COUNT(*) or aggregate column (Total, Count, etc.), that IS the answer to 'how many' questions — state the number directly.\n3. Never say 'data is not available' or 'I cannot find' when LIVE DATA is present.\n4. Be concise and precise. Lead with the number or key fact.\n5. Answer in the same language as the question."
  },
  "ChatDatabases": [
    {
      "Name": "MyDatabase",
      "DisplayName": "My Business Database",
      "ConnectionString": "Server=YOUR_SERVER;Database=YOUR_DATABASE;User Id=YOUR_USER;Password=YOUR_PASSWORD;Connection Timeout=30;TrustServerCertificate=true;ApplicationIntent=ReadOnly;",
      "IsReadOnly": true,
      "Topics": [
        "sales", "order", "product", "customer", "employee", "purchase",
        "production", "inventory", "person", "address", "department"
      ],
      "Tables": [],
      "TableGroups": [
        {
          "Name": "SalesOverview",
          "Description": "Sales orders, order details, customers, salesperson performance, and territory data",
          "EntityLabel": "customer or product",
          "TriggerKeywords": [ "sales order", "order detail", "sales revenue", "salesperson", "territory" ],
          "EntityRegex": "",
          "Tables": [
            "Sales.SalesOrderHeader",
            "Sales.SalesOrderDetail",
            "Sales.Customer"
          ]
        }
      ]
    }
  ],
  "AllowedHosts": "*"
}
